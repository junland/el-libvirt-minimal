 .../qemu/firmware/45-ovmf-sev-stateless.json  | 31 ++++++++
 .../qemu/firmware/55-ovmf-sb-combined.json    | 33 ++++++++
 .../usr/share/qemu/firmware/60-ovmf-sb.json   |  1 +
 tests/qemufirmwaretest.c                      | 31 ++++++--
 8 files changed, 246 insertions(+), 21 deletions(-)
